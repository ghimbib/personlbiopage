---
const experiences = [
  {
    company: "Orbex Group",
    role: "Product Strategy & Execution",
    period: "Oct 2023 – Mar 2026",
    badge: "Automation",
    summary: "Owned product strategy across industrial hardware, CRM/workflow, analytics, and GTM. Built the roadmap, secured funding, and improved lead quality through better systems and funnel design.",
    products: "Wheel drives, BLDC motors, slip rings, CRM workflows",
    icon: `<path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    company: "Viessmann",
    role: "Portfolio & Product Leadership",
    period: "Jan 2021 – Aug 2023",
    badge: "Climate Tech",
    summary: "Led a multi-product portfolio across apps, portals, design tools, and connected products. Drove launches, growth, and better customer experience through tighter roadmap and execution discipline.",
    products: "ViCare app, ViGuide portal, ViPlan design tool, connected heat pumps",
    icon: `<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    company: "Baker Hughes",
    role: "Product & Engineering Leadership",
    period: "Jun 2012 – Sep 2020",
    badge: "Energy",
    summary: "Led product and engineering work across hardware and digital product lines, improving launches, eCommerce performance, and operating workflows across 7 global regions.",
    products: "Hybrid drill bits, eCommerce drilling tools, inventory platforms",
    icon: `<path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  }
];
---

<section id="experience" class="py-20 sm:py-28 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <div class="section-label" data-animate>
      <span class="section-number">02</span>
      <span class="section-line"></span>
      <span class="section-label-text">Experience</span>
    </div>

    <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-12 sm:mb-16 text-center sm:text-left" data-animate data-delay="100">
      Where I've been<span class="gradient-text">.</span>
    </h2>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[5px] top-0 bottom-0 w-px bg-gradient-to-b from-accent via-border to-transparent"></div>

      <div class="space-y-6 sm:space-y-8">
        {experiences.map((exp, i) => (
          <div class="relative pl-8 sm:pl-12" data-animate data-delay={String(i * 100)}>
            <!-- Timeline dot -->
            <div class="absolute left-0 top-3">
              <div class="timeline-dot"></div>
            </div>

            <!-- Card -->
            <div class="bg-bg-card border border-border rounded-xl p-5 sm:p-6 card-hover timeline-card">
              <!-- Header -->
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-2 mb-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg bg-accent-subtle flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={exp.icon} />
                  </div>
                  <div>
                    <h3 class="text-base sm:text-lg font-semibold text-text-primary leading-tight">{exp.company}</h3>
                    <p class="text-accent text-sm font-medium">{exp.role}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 ml-11 sm:ml-0">
                  <span class="text-text-muted text-xs sm:text-sm font-mono">{exp.period}</span>
                  <span class="text-[10px] sm:text-xs px-2 py-0.5 rounded-full bg-accent-subtle text-accent border border-accent/20">
                    {exp.badge}
                  </span>
                </div>
              </div>

              <!-- Summary -->
              <p class="text-text-secondary text-sm leading-relaxed mb-3">{exp.summary}</p>

              <!-- Products -->
              <p class="text-text-muted text-xs font-mono">
                <span class="text-accent/60">Products:</span> {exp.products}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
