---
const projects = [
  {
    title: "DojoGate CRM",
    description: "CRM and CPQ platform for SMB hardware teams, built around pipeline visibility, pricing logic, quoting, and day-to-day sales ops.",
    tags: ["TypeScript", "React", "Node.js", "PostgreSQL"],
    status: "In Development",
    link: "https://dojogate.ai",
    icon: `<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    title: "DocHaven",
    description: "AI document workspace for searching, organizing, and pulling useful insight from personal or business documents.",
    tags: ["TypeScript", "React", "Supabase", "AI/ML"],
    status: "Live",
    link: "https://dochaven.ai",
    icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    title: "AI Workflow Infrastructure",
    description: "Internal multi-agent system for research, execution, and decision support across content, ops, and strategy.",
    tags: ["AI/ML", "Node.js", "Multi-Agent", "Automation"],
    status: "Internal",
    icon: `<path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    title: "ShieldRA",
    description: "AI-enabled compliance platform for healthcare teams, built to speed up policy, evidence, and audit workflows.",
    tags: ["Healthcare", "AI/ML", "Compliance", "SaaS"],
    status: "In Development",
    link: "https://shieldraa.ai",
    icon: `<path d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  },
  {
    title: "TaskMesh",
    description: "Open-source task queue protocol and Python reference implementation for multi-agent systems, built around safe concurrency, routing, retries, stale detection, and CLI support.",
    tags: ["Python", "Open Source", "Multi-Agent", "Infrastructure"],
    status: "Released",
    link: "https://github.com/ghimbib/taskmesh",
    icon: `<path d="M8 8h8m-8 8h8M7 8a1 1 0 11-2 0 1 1 0 012 0zm0 8a1 1 0 11-2 0 1 1 0 012 0zm12-8a1 1 0 11-2 0 1 1 0 012 0zm0 8a1 1 0 11-2 0 1 1 0 012 0zM8 8v8m8-8v8" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`
  }
];
---

<section id="projects" class="py-28 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <div class="section-label" data-animate>
      <span class="section-number">05</span>
      <span class="section-line"></span>
      <span class="section-label-text">Projects</span>
    </div>

    <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4 text-center sm:text-left" data-animate data-delay="100">
      Products & Platforms<span class="gradient-text">.</span>
    </h2>
    <p class="text-text-secondary text-lg mb-12 max-w-2xl text-center sm:text-left" data-animate data-delay="150">
      A few products and systems I’ve built or am actively developing.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <div data-animate data-delay={String(i * 100 + 200)} class="bg-bg-card border border-border rounded-xl p-7 card-hover flex flex-col group">
          <div class="flex items-center justify-between mb-5">
            <div class="w-11 h-11 rounded-lg bg-accent-subtle flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={project.icon} />
            </div>
            <div class="flex items-center gap-2">
              {project.link && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={`Visit ${project.title}`}>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
              <span class="text-xs px-2.5 py-1 rounded-full bg-accent-subtle text-accent border border-accent/20 font-mono">
                {project.status}
              </span>
            </div>
          </div>

          {project.link ? (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="block">
              <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">{project.title}</h3>
            </a>
          ) : (
            <h3 class="text-lg font-semibold text-text-primary mb-2">{project.title}</h3>
          )}
          <p class="text-text-secondary text-sm leading-relaxed mb-6 flex-grow">{project.description}</p>

          <div class="flex flex-wrap gap-2 pt-4 border-t border-border">
            {project.tags.map((tag) => (
              <span class="text-xs text-text-muted font-mono">{tag}</span>
            ))}
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
