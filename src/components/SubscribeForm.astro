---
interface Props {
  compact?: boolean;
  className?: string;
}

const {
  compact = false,
  className = '',
} = Astro.props;

const formId = compact ? 'compact' : 'full';
const eyebrow = 'Newsletter';
const title = 'Get new essays in your inbox';
const helper = 'No spam. Just new posts and occasional useful notes.';
---

<section class={`subscribe-card ${compact ? 'subscribe-card--compact' : ''} ${className}`.trim()} data-subscribe-root>
  {!compact && (
    <div class="subscribe-card__copy">
      <p class="subscribe-card__eyebrow">{eyebrow}</p>
      <h2 class="subscribe-card__title">{title}</h2>
      <p class="subscribe-card__helper">{helper}</p>
    </div>
  )}

  <form class="subscribe-form" data-subscribe-form novalidate>
    <label class="sr-only" for={`subscribe-email-${formId}`}>Email address</label>
    <div class="subscribe-form__row">
      <input
        id={`subscribe-email-${formId}`}
        name="email"
        type="email"
        inputmode="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
        class="subscribe-form__input"
        aria-describedby={`subscribe-status-${formId}`}
      />
      <button type="submit" class="subscribe-form__button" data-hover>
        Subscribe
      </button>
    </div>
    <p
      id={`subscribe-status-${formId}`}
      class="subscribe-form__status"
      data-subscribe-status
      role="status"
      aria-live="polite"
    ></p>
  </form>
</section>

<script>
  const roots = Array.from(document.querySelectorAll('[data-subscribe-root]'));

  const messages = {
    success: "You're in. Check your inbox to confirm.",
    invalid_email: 'Enter a valid email address.',
    already_subscribed: "You're already subscribed. Check your inbox if you need the confirmation email again.",
    unavailable: 'Subscriptions are not available right now. Please try again soon.',
    error: 'Something went wrong. Please try again in a moment.',
  };

  for (const root of roots) {
    const form = root.querySelector('[data-subscribe-form]');
    const status = root.querySelector('[data-subscribe-status]');
    const input = root.querySelector('input[name="email"]');
    const button = root.querySelector('button[type="submit"]');

    if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement) || !(input instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) continue;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = input.value.trim();
      status.textContent = '';
      status.dataset.state = '';

      if (!email || !input.checkValidity()) {
        status.textContent = messages.invalid_email;
        status.dataset.state = 'error';
        input.focus();
        return;
      }

      button.disabled = true;
      const originalLabel = button.textContent;
      button.textContent = 'Submitting...';

      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email }),
        });

        const result = await response.json().catch(() => ({ status: 'error' }));
        const state = typeof result?.status === 'string' ? result.status : 'error';
        const message = messages[state] ?? messages.error;

        status.textContent = message;
        status.dataset.state = state === 'success' || state === 'already_subscribed' ? 'success' : 'error';

        if (state === 'success' || state === 'already_subscribed') {
          form.reset();
        }
      } catch {
        status.textContent = messages.error;
        status.dataset.state = 'error';
      } finally {
        button.disabled = false;
        button.textContent = originalLabel;
      }
    });
  }
</script>

<style>
  .subscribe-card {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-bg-card) 88%, transparent);
  }

  .subscribe-card--compact {
    padding: 1.25rem;
    gap: 1rem;
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--color-bg-card) 92%, transparent);
  }

  .footer-subscribe.subscribe-card--compact {
    padding: 0;
    gap: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .subscribe-card__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }

  .subscribe-card--compact .subscribe-card__eyebrow {
    margin-bottom: 0.35rem;
  }

  .subscribe-card__title {
    margin: 0;
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    line-height: 1.15;
    color: var(--color-text-primary);
    font-weight: 700;
  }

  .subscribe-card--compact .subscribe-card__title {
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    line-height: 1.25;
  }

  .subscribe-card__helper {
    margin: 0.75rem 0 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .subscribe-card--compact .subscribe-card__helper {
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }

  .subscribe-form {
    display: grid;
    gap: 0.75rem;
  }

  .subscribe-form__row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .subscribe-form__input {
    width: 100%;
    min-height: 3rem;
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    background: var(--color-bg);
    color: var(--color-text-primary);
    padding: 0.875rem 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .subscribe-form__input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .subscribe-form__button {
    min-height: 3rem;
    border: 0;
    border-radius: 0.875rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-accent);
    color: #081310;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  .subscribe-form__button:hover:not(:disabled) {
    transform: translateY(-1px);
    background: var(--color-accent-hover);
  }

  .subscribe-form__button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .subscribe-form__status {
    min-height: 1.5rem;
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .subscribe-form__status[data-state='success'] {
    color: var(--color-accent);
  }

  .subscribe-form__status[data-state='error'] {
    color: #e06c75;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .subscribe-card {
      grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
      align-items: center;
    }

    .subscribe-form__row {
      flex-direction: row;
      align-items: stretch;
    }

    .subscribe-form__button {
      flex-shrink: 0;
    }
  }
</style>
