---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SubscribeCTA from '../../components/SubscribeCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft && !post.data.hidden)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = posts[0];

const categoryOrder = ['AI Systems', 'Product Lessons', 'Personal Stories'];
const categoryMeta = {
  'AI Systems': {
    description: 'Agent orchestration, AI systems, reliability, and build-in-public lessons from running real workflows.',
  },
  'Product Lessons': {
    description: 'Product thinking, strategy, and operator lessons that transfer beyond any one tool or team.',
  },
  'Personal Stories': {
    description: 'More human stories, lived moments, and real-world challenges that do not fit the usual tech essay mold.',
  },
};

const groupedPosts = categoryOrder
  .map((category) => ({
    category,
    id: category.toLowerCase().replace(/\s+/g, '-'),
    description: categoryMeta[category].description,
    posts: posts.filter((post) => post.data.category === category),
  }))
  .filter((group) => group.posts.length > 0);
---

<Layout title="Blog — Bibek Ghimire" description="Thoughts on AI, product management, and building in public.">
  <Nav />
  <main class="pt-24 md:pt-32 pb-16 md:pb-20 px-5 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10 md:mb-16" data-animate>
        <div class="flex items-center gap-4 mb-4">
          <span class="text-accent font-mono text-sm font-bold">blog</span>
          <span class="h-px bg-border flex-1"></span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold leading-[0.95] mb-4">
          Lessons from building<span class="gradient-text">.</span>
        </h1>
        <p class="text-text-secondary text-base sm:text-lg max-w-2xl leading-relaxed">
          What I'm learning about AI agents, product management, shipping software, and the occasional story that matters enough to write down.
        </p>

        {featuredPost && (
          <div class="mt-6">
            <p class="text-xs uppercase tracking-[0.18em] text-text-muted font-mono mb-3">Latest</p>
            <a href={`/blog/${featuredPost.id.replace(/\.md$/, '')}`} class="block group">
              <article class="rounded-2xl border border-border bg-bg-card p-3 sm:p-4 transition-colors hover:border-accent/30">
                <div class="flex items-start gap-3 sm:gap-4">
                  {featuredPost.data.image && (
                    <div class="w-24 sm:w-36 aspect-[4/3] overflow-hidden rounded-xl shrink-0">
                      <img
                        src={featuredPost.data.image}
                        alt={featuredPost.data.title}
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                        style={featuredPost.data.imagePosition ? `object-position: ${featuredPost.data.imagePosition};` : undefined}
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 mb-2 flex-wrap text-xs font-mono text-text-muted">
                      <span class="text-accent">{featuredPost.data.category}</span>
                      <span class="text-border">·</span>
                      <time>
                        {featuredPost.data.date.toLocaleDateString('en-US', {
                          year: 'numeric', month: 'short', day: 'numeric'
                        })}
                      </time>
                    </div>
                    <h2 class="text-lg sm:text-2xl font-bold text-text-primary group-hover:text-accent transition-colors leading-tight mb-2">
                      {featuredPost.data.title}
                    </h2>
                    <p class="text-sm sm:text-base text-text-secondary leading-relaxed">
                      {featuredPost.data.description}
                    </p>
                  </div>
                </div>
              </article>
            </a>
          </div>
        )}

        <div class="mt-5 rounded-2xl border border-border bg-bg-card/60 p-3 sm:p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-text-muted font-mono mb-3">Browse by type</p>
          <div class="grid grid-cols-1 gap-2 sm:flex sm:flex-wrap sm:gap-3">
            {groupedPosts.map((group) => (
              <a
                href={`#${group.id}`}
                class="group flex items-center justify-between rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text-secondary hover:border-accent/30 hover:bg-bg-card transition-colors sm:min-w-[200px]"
              >
                <span class="font-medium text-text-primary">{group.category}</span>
                <span class="inline-flex items-center gap-2 text-xs font-mono text-text-muted">
                  <span>{group.posts.length}</span>
                  <span class="text-accent group-hover:translate-x-0.5 transition-transform">→</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="space-y-10 md:space-y-14">
        {groupedPosts.map((group, groupIndex) => (
          <section id={group.id} data-animate data-delay={String(groupIndex * 100 + 100)}>
            <div class="flex items-center gap-4 mb-3">
              <h2 class="text-xl sm:text-3xl font-bold text-text-primary">{group.category}</h2>
              <span class="h-px bg-border flex-1"></span>
            </div>
            <p class="text-text-secondary text-sm sm:text-base max-w-2xl mb-5 leading-relaxed">{group.description}</p>

            <div class="space-y-6 sm:space-y-8">
              {group.posts.map((post) => (
                <a 
                  href={`/blog/${post.id.replace(/\.md$/, '')}`}
                  class="block group"
                >
                  <article class="bg-bg-card border border-border rounded-xl overflow-hidden card-hover transition-all">
                    {post.data.image && (
                      <div class="aspect-[5/2] overflow-hidden">
                        <img 
                          src={post.data.image} 
                          alt={post.data.title}
                          class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                          style={post.data.imagePosition ? `object-position: ${post.data.imagePosition};` : undefined}
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="p-5 sm:p-8">
                      <div class="flex items-center gap-3 mb-3 flex-wrap">
                        <time class="text-text-muted text-sm font-mono">
                          {post.data.date.toLocaleDateString('en-US', { 
                            year: 'numeric', month: 'long', day: 'numeric' 
                          })}
                        </time>
                        <div class="hidden sm:flex items-center gap-3">
                          <span class="text-border">·</span>
                          <div class="flex gap-2">
                            {post.data.tags.slice(0, 3).map(tag => (
                              <span class="text-xs px-2 py-0.5 rounded-full bg-accent-subtle text-accent border border-accent/20 font-mono">
                                {tag}
                              </span>
                            ))}
                          </div>
                        </div>
                      </div>
                      <h3 class="text-xl sm:text-2xl font-bold text-text-primary group-hover:text-accent transition-colors mb-2">
                        {post.data.title}
                      </h3>
                      <p class="text-text-secondary text-sm sm:text-base leading-relaxed">
                        {post.data.description}
                      </p>
                      <div class="mt-4 flex items-center gap-2 text-accent text-sm font-medium">
                        <span>Read article</span>
                        <span class="group-hover:translate-x-1 transition-transform">→</span>
                      </div>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <section id="subscribe" class="mt-16" data-animate data-delay="200">
        <SubscribeCTA />
      </section>
    </div>
  </main>
  <Footer />
</Layout>
